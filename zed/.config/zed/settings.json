// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)

{
  // general settings
  "tabs": {
    "file_icons": true,
    "git_status": true,
  },
  "max_tabs": 12,
  "minimap": {
    "max_width_columns": 100,
    "show": "always",
  },
  "preferred_line_length": 120,
  "soft_wrap": "bounded",
  "use_smartcase_search": true,
  "inlay_hints": {
    "enabled": true,
  },
  "semantic_tokens": "combined",
  "ui_font_family": ".ZedSans",
  "ui_font_size": 17.0,
  "buffer_font_family": ".ZedMono",
  // "buffer_font_family": "JetBrains Mono",
  "buffer_font_size": 15.0,
  "buffer_font_features": {
    "calt": false,
  },
  "agent_ui_font_size": 18.0,
  "agent_buffer_font_size": 15.0,
  "theme": {
    "mode": "system",
    "light": "Monokai Pro (raptor)",
    "dark": "Monokai Pro (raptor)",
  },
  // "colorize_brackets": true,
  "icon_theme": "Colored Zed Icons Theme Dark",
  "cli_default_open_behavior": "new_window",
  "terminal": {
    "shell": {
      "program": "fish",
    },
    "copy_on_select": true,
    "detect_venv": "off",
  },

  // panels
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
    "tree_view": true,
  },

  // ai
  "edit_predictions": {
    "provider": "copilot",
  },
  "agent": {
    "sidebar_side": "right",
    "dock": "right",
    "default_profile": "ask",
    "default_model": {
      // "provider": "copilot_chat",
      // "model": "gpt-5-mini",
      // "enable_thinking": false,
      "effort": "high",
      "provider": "anthropic",
      "model": "claude-opus-4-7-latest",
      "enable_thinking": true,
    },
    "favorite_models": [],
    "model_parameters": [],
  },

  // disable telemetry
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },

  // rust-analyzer
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "rustfmt": {
          "extraArgs": ["--config", "imports_granularity=Module,group_imports=StdExternalCrate"],
        },
        "check": {
          "command": "clippy",
        },
        "checkOnSave": true,
        "cargo": { "allFeatures": true },
        "procMacro": { "enable": true },
      },
    },
  },

  // zed-highlight extension colors
  "global_lsp_settings": {
    "semantic_token_rules": [
      { "token_type": "highlight-0", "foreground_color": "#F5B041", "background_color": "#F5B04150" },
      { "token_type": "highlight-1", "foreground_color": "#85C1E9", "background_color": "#85C1E950" },
      { "token_type": "highlight-2", "foreground_color": "#CD6155", "background_color": "#CD615550" },
      { "token_type": "highlight-3", "foreground_color": "#AF7AC5", "background_color": "#AF7AC550" },
      { "token_type": "highlight-4", "foreground_color": "#48C9B0", "background_color": "#48C9B050" },
      { "token_type": "highlight-5", "foreground_color": "#F4D03F", "background_color": "#F4D03F50" },
      { "token_type": "highlight-6", "foreground_color": "#52BE80", "background_color": "#52BE8050" },
      { "token_type": "highlight-7", "foreground_color": "#FF9933", "background_color": "#FF993350" },
    ],
  },

  // languages
  "languages": {
    "Rust": {
      // "preferred_line_length": 100,
    },
    "TOML": {
      "formatter": {
        "external": {
          "command": "taplo",
          "arguments": ["fmt", "-"],
        },
      },
    },
    "Markdown": {
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "file.md"],
        },
      },
      "format_on_save": "on",
    },
  },
}
