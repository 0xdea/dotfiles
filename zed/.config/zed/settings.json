// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)

// general settings
{
  "git_panel": {
    "tree_view": true,
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
  },
  "max_tabs": 10,
  "minimap": {
    "max_width_columns": 100,
    "show": "always",
  },
  "preferred_line_length": 120,
  "soft_wrap": "preferred_line_length",
  "use_smartcase_search": true,
  "inlay_hints": {
    "enabled": true,
  },
  "ui_font_size": 17.0,
  "buffer_font_size": 15.0,
  "agent_ui_font_size": 17.0,
  "agent_buffer_font_size": 14.0,
  "buffer_font_features": {
    "calt": false,
  },
  "theme": {
    "mode": "system",
    "light": "Monokai Pro (raptor)",
    "dark": "Monokai Pro (raptor)",
  },
  "terminal": {
    "shell": {
      "program": "fish",
    },
    "copy_on_select": true,
    "detect_venv": "off",
  },

  // disable telemetry
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },

  // ai
  "edit_predictions": {
    "provider": "copilot",
  },
  "agent": {
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-5-mini",
      "enable_thinking": false,
    },
    "favorite_models": [],
    "model_parameters": [],
  },

  // rust-analyzer
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "check": {
          "command": "clippy",
        },
        "checkOnSave": true,
        "cargo": { "allFeatures": true },
        "procMacro": { "enable": true },
      },
    },
  },

  // languages
  "languages": {
    "Rust": {
      // "preferred_line_length": 100,
    },
    "TOML": {
      "formatter": {
        "external": {
          "command": "taplo",
          "arguments": ["fmt", "-"],
        },
      },
    },
    "Markdown": {
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "file.md"],
        },
      },
      "format_on_save": "on",
    },
  },
}
